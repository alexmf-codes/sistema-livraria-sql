USE livraria;

-- ========================================================
-- NÍVEL BÁSICO
-- ========================================================

-- Cenário: A diretoria quer saber quais gêneros literários têm mais títulos disponíveis.
SELECT 
    categoria, 
    COUNT(*) AS total_de_livros 
FROM livros
GROUP BY categoria
ORDER BY total_de_livros DESC;

-- Cenário: O time de marketing precisa saber em quais estados focar suas campanhas de frete grátis.
SELECT 
    estado, 
    COUNT(idendereco) AS total_clientes 
FROM enderecos
GROUP BY estado
ORDER BY total_clientes DESC;

-- ========================================================
-- NÍVEL INTERMEDIÁRIO (JOINs)
-- ========================================================

-- Cenário: A aplicação precisa exibir os livros com o nome do autor, cruzando as duas tabelas.
SELECT 
    l.titulo AS Livro, 
    l.categoria AS Categoria, 
    l.ano_publicacao AS Ano, 
    a.nome AS Autor, 
    a.nacionalidade AS Origem
FROM livros l
INNER JOIN autores a 
    ON l.id_autor = a.idautor
ORDER BY l.ano_publicacao DESC;

-- Cenário: O time de SAC precisa de uma lista de clientes, suas cidades, contendo apenas telefones celulares.
SELECT 
    c.nome AS Cliente, 
    c.cpf, 
    e.cidade, 
    e.estado, 
    t.numero AS Celular
FROM clientes c
INNER JOIN enderecos e 
    ON c.idcliente = e.id_cliente
INNER JOIN telefones t 
    ON c.idcliente = t.id_cliente
WHERE t.tipo = 'cel';

-- Cenário: Verificar se existe algum cliente na base que foi cadastrado sem um endereço (auditoria de falhas).
SELECT 
    c.nome, 
    c.email 
FROM clientes c
LEFT JOIN enderecos e 
    ON c.idcliente = e.id_cliente
WHERE e.idendereco IS NULL;
